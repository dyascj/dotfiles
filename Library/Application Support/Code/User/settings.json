{
    "security.workspace.trust.untrustedFiles": "newWindow",
    "workbench.colorTheme": "Dark+",
    "python.defaultInterpreterPath": "/opt/homebrew/bin/python3",
    "claudeCode.preferredLocation": "panel",
    "terminal.integrated.env.osx": {
        "PATH": "${env:HOME}/.local/bin:${env:PATH}"
    },
    "terminal.integrated.smoothScrolling": false,
    "window.titleBarStyle": "custom",

    "vscode_vibrancy.opacity": -1,
    "vscode_vibrancy.theme": "Default Dark",
    "vscode_vibrancy.type": "under-window",

    "workbench.colorCustomizations": {
        "editor.background": "#101a194d",
        "editorGutter.background": "#101a1900",
        "editorLineNumber.foreground": "#6e8380",
        "editorLineNumber.activeForeground": "#e8e0d4",
        "sideBar.background": "#101a194d",
        "sideBar.border": "#2e403d",
        "sideBarSectionHeader.background": "#18242270",
        "activityBar.background": "#101a194d",
        "activityBar.foreground": "#e8e0d4",
        "activityBar.inactiveForeground": "#6e8380",
        "activityBar.border": "#2e403d",
        "statusBar.background": "#18242280",
        "statusBar.border": "#2e403d",
        "titleBar.activeBackground": "#18242270",
        "titleBar.inactiveBackground": "#18242270",
        "titleBar.border": "#2e403d",
        "panel.background": "#101a1900",
        "panel.border": "#2e403d",
        "tab.activeBackground": "#101a1900",
        "tab.inactiveBackground": "#101a194d",
        "tab.border": "#2e403d",
        "tab.activeBorder": "#63a68f",
        "editorGroupHeader.tabsBackground": "#101a1900",
        "editorGroupHeader.tabsBorder": "#2e403d",
        "dropdown.background": "#18242299",
        "dropdown.border": "#2e403d",
        "input.background": "#18242299",
        "input.border": "#2e403d",
        "quickInput.background": "#101a19e6",
        "list.activeSelectionBackground": "#2e403d80",
        "list.hoverBackground": "#2e403d80",
        "list.inactiveSelectionBackground": "#2e403d80",
        "scrollbarSlider.background": "#2e403d80",
        "scrollbarSlider.hoverBackground": "#2e403d",
        "scrollbarSlider.activeBackground": "#6e8380",
        "terminal.background": "#00000000",
        "editorPane.background": "#101a1900",
        "editorGroupHeader.noTabsBackground": "#101a1900",
        "breadcrumb.background": "#101a1900",
        "panelStickyScroll.background": "#101a1900",
        "tab.unfocusedActiveBackground": "#101a1900",
        "sideBarTitle.background": "#101a194d",
        "sideBarStickyScroll.background": "#101a194d",
        "editorStickyScroll.background": "#101a194d",
        "editorStickyScrollGutter.background": "#101a194d",
        "tab.unfocusedInactiveBackground": "#101a194d",
