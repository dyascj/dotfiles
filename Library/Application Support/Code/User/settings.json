        "notifications.background": "#101a19e6",
        "notificationCenterHeader.background": "#101a19e6",
        "menu.background": "#101a19e6",
        "editorCursor.foreground": "#d3a778",
        "editor.selectionBackground": "#2e403d80",
        "editor.lineHighlightBackground": "#18242240",
        "focusBorder": "#63a68f80",
        "statusBar.foreground": "#c9c2b4",
        "badge.background": "#63a68f",
        "badge.foreground": "#101a19",
        "button.background": "#3d6b5e",
