    "editor.tokenColorCustomizations": {
        "[Dark+]": {
            "comments": "#6e8380",
            "strings": "#d3a778",
            "keywords": "#bd8f95",
            "functions": "#a2bfcd",
            "numbers": "#dc8a75",
            "types": "#83b8b0",
            "variables": "#e8e0d4"
        }
    },
    "terminal.integrated.gpuAcceleration": "off",
    "window.systemColorTheme": "dark",
    "window.autoDetectColorScheme": false,
    "editor.accessibilitySupport": "off"
